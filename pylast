class _VersionAction(argparse.Action):
    """Colorized version output with a leading blank line."""

    def __init__(self, option_strings, dest=argparse.SUPPRESS,
                 default=argparse.SUPPRESS, **kwargs):
        super().__init__(option_strings=option_strings, dest=dest,
                         default=default, nargs=0, **kwargs)

    def __call__(self, parser, namespace, values, option_string=None):
        use_color = sys.stdout.isatty()
        name = _color(PROG, "bold", use_color)
        title = _color(f"-- {TITLE}", "gray", use_color) if TITLE else ""
        ver = _color(VERSION, "bold_cyan", use_color)
        line1 = f"{name} {title}" if title else name
        print(f"\n{line1}\nVersion: {ver}")
        parser.exit()


