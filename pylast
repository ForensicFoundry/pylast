def _decode_cstring(raw):
    try:
        idx = raw.index(b"\x00")
        return raw[:idx].decode("utf-8", errors="replace")
    except ValueError:
        return raw.decode("utf-8", errors="replace")


def _format_ip(addr_v6):
    a, b, c, d = addr_v6
    if b == 0 and c == 0 and d == 0:
        if a == 0:
            return "0.0.0.0"
        raw = struct.pack("<I", a)
        return f"{raw[0]}.{raw[1]}.{raw[2]}.{raw[3]}"
    raw = struct.pack("<4I", a, b, c, d)
    try:
        return str(ipaddress.IPv6Address(raw))
    except Exception:
        return ":".join(f"{raw[i]:02x}{raw[i+1]:02x}" for i in range(0, 16, 2))


def _format_timestamp(tv_sec, tv_usec):
    if tv_sec == 0 and tv_usec == 0:
        return ""
    dt = datetime.fromtimestamp(tv_sec, tz=timezone.utc)
    return f"{dt.strftime('%Y-%m-%d %H:%M:%S')}.{tv_usec:06d}"


def _format_timestamp_us(us):
    """Format a microsecond-epoch timestamp (used by wtmpdb)."""
    if not us:
        return ""
    sec = us // 1_000_000
    usec = us % 1_000_000
    dt = datetime.fromtimestamp(sec, tz=timezone.utc)
    return f"{dt.strftime('%Y-%m-%d %H:%M:%S')}.{usec:06d}"


def _iso_to_utc_str(iso_str):
    """Parse an ISO 8601 timestamp with timezone and return UTC string."""
    dt = datetime.fromisoformat(iso_str)
    dt_utc = dt.astimezone(timezone.utc)
    return f"{dt_utc.strftime('%Y-%m-%d %H:%M:%S')}.{dt_utc.microsecond:06d}"


def _iso_to_epoch_us(iso_str):
    """Parse an ISO 8601 timestamp and return microseconds since epoch (UTC)."""
    dt = datetime.fromisoformat(iso_str)
    dt_utc = dt.astimezone(timezone.utc)
    return int(dt_utc.timestamp() * 1_000_000) + dt_utc.microsecond % 1_000_000


def _format_duration(seconds):
    if seconds is None or seconds < 0:
        return ""
    total = int(seconds)
    days, rem = divmod(total, 86400)
    hours, rem = divmod(rem, 3600)
    mins, secs = divmod(rem, 60)
    if days > 0:
        return f"{days}d {hours:02d}:{mins:02d}:{secs:02d}"
    return f"{hours:02d}:{mins:02d}:{secs:02d}"


def _open_log_file(filepath):
    """Open a plain text or .gz log file for reading."""
    if filepath.endswith(".gz"):
        return gzip.open(filepath, "rt", encoding="utf-8", errors="replace")
    return open(filepath, encoding="utf-8", errors="replace")


