# Legacy binary parsing
# ---------------------------------------------------------------------------

def _parse_legacy_record(data):
    fields = struct.unpack(UTMP_STRUCT_FORMAT, data)
    ut_type = fields[0]
    addr = (fields[11], fields[12], fields[13], fields[14])
    return {
        "type": ut_type,
        "type_name": LEGACY_TYPE_NAMES.get(ut_type, f"UNKNOWN({ut_type})"),
        "pid": fields[1],
        "user": _decode_cstring(fields[4]),
        "line": _decode_cstring(fields[2]),
        "id": _decode_cstring(fields[3]),
        "host": _decode_cstring(fields[5]),
        "ip": _format_ip(addr),
        "tv_sec": fields[9],
        "tv_usec": fields[10],
        "timestamp_str": _format_timestamp(fields[9], fields[10]),
        "e_term": fields[6],
        "e_exit": fields[7],
        "session": fields[8],
        "logout_str": "",
        "duration_str": "",
        "source": "",
    }


def _open_binary_file(filepath):
    """Open a binary file for reading, transparently handling .gz."""
    if filepath.endswith(".gz"):
        return gzip.open(filepath, "rb")
    return open(filepath, "rb")


def _parse_legacy_file(filepath):
    records = []
    with _open_binary_file(filepath) as f:
        while True:
            data = f.read(UTMP_STRUCT_SIZE)
            if len(data) < UTMP_STRUCT_SIZE:
                break
            records.append(_parse_legacy_record(data))
    return records


# ---------------------------------------------------------------------------
# wtmpdb (SQLite) parsing
# ---------------------------------------------------------------------------

def _parse_wtmpdb_file(filepath):
    """Parse a wtmpdb SQLite database. Returns list of record dicts."""
    conn = sqlite3.connect(f"file:{filepath}?mode=ro", uri=True)
    try:
        cursor = conn.cursor()
        cursor.execute("SELECT ID, Type, User, Login, Logout, TTY, RemoteHost, Service FROM wtmp")
        rows = cursor.fetchall()
    except sqlite3.OperationalError as exc:
        conn.close()
        raise ValueError(f"Failed to query wtmpdb: {exc}") from exc
    conn.close()

    records = []
    for row in rows:
        db_id, db_type, user, login_us, logout_us, tty, remote_host, service = row

        type_name = WTMPDB_TYPE_NAMES.get(db_type, f"UNKNOWN({db_type})")

        login_str = _format_timestamp_us(login_us)

        if logout_us:
            logout_str = _format_timestamp_us(logout_us)
            duration_sec = (logout_us - login_us) / 1_000_000
            duration_str = _format_duration(duration_sec)
        else:
            if db_type == 1:
                logout_str = "still running"
            else:
                logout_str = "still logged in"
            duration_str = ""

        records.append({
            "type": db_type,
            "type_name": type_name,
            "user": user or "",
            "login_us": login_us or 0,
            "login_str": login_str,
            "logout_str": logout_str,
            "duration_str": duration_str,
            "tty": tty or "",
            "remote_host": remote_host or "",
            "service": service or "",
            "source": "",
        })

    return records


