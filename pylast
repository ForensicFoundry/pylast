# CLI
# ---------------------------------------------------------------------------

def _build_parser():
    parser = _Parser(
        prog=PROG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "-v",
        "--version",
        action=_VersionAction,
        help="show version information and exit",
    )

    source = parser.add_mutually_exclusive_group(required=True)
    source.add_argument(
        "-f",
        "--file",
        metavar="FILE",
        nargs="+",
        help="Parse wtmp, btmp, utmp, or wtmpdb file(s), including .gz "
        "compressed. All files must be the same format and type.",
    )
    source.add_argument(
        "-a",
        "--auth",
        metavar="FILE",
        nargs="+",
        help="Parse auth.log file(s). Supports plain text and .gz compressed "
        "files. Shell wildcards work (e.g. auth.log*).",
    )
    source.add_argument(
        "-j",
        "--journal",
        metavar="DIR",
        help="Parse a systemd journal directory. Requires journalctl to be "
        "installed on this system.",
    )

    output = parser.add_mutually_exclusive_group()
    output.add_argument(
        "-t",
        action="store_true",
        default=False,
        help="Output as tab-separated values with a header row.",
    )
    output.add_argument(
        "-s",
        "--sqlite",
        metavar="FILE",
        help="Write results to a SQLite database instead of stdout.",
    )

    parser.add_argument(
        "--all",
        action="store_true",
        default=False,
        dest="show_all",
        help="Show all record types when using -f. By default, only "
        "USER_PROCESS, BOOT_TIME, and RUN_LVL are shown for wtmp/wtmpdb. "
        "Has no effect with -a or -j.",
    )
    return parser


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def _sort_key(fmt_key):
    if fmt_key == FMT_WTMPDB:
        return lambda r: r["login_us"]
    if fmt_key in (FMT_AUTH, FMT_JOURNAL):
        return lambda r: r["sort_us"]
    return lambda r: (r["tv_sec"], r["tv_usec"])


def _emit(records, fmt_key, args, source_paths, color_out):
    """Output records to stdout or SQLite depending on flags."""
    if args.sqlite:
        ok = _write_to_sqlite(args.sqlite, records, fmt_key, source_paths,
                              color_out)
        if not ok:
            sys.exit(1)
    else:
        _print_records(records, fmt_key, args.t, color_out)


def main():
    parser = _build_parser()
    args = parser.parse_args()

    color_out = sys.stdout.isatty()
    color_err = sys.stderr.isatty()

    # =======================================================================
    # Mode: auth.log (-a)
    # =======================================================================
    if args.auth:
        all_records = _parse_auth_files(args.auth, color_err)
        if not all_records:
            _msg("No login/auth events found in the provided file(s).",
                 "bold_yellow", color_out)
            sys.exit(0)
        all_records.sort(key=_sort_key(FMT_AUTH), reverse=True)
        _emit(all_records, FMT_AUTH, args,
              [os.path.abspath(p) for p in args.auth], color_out)
        return

    # =======================================================================
    # Mode: journal (-j)
    # =======================================================================
    if args.journal:
        all_records = _parse_journal(args.journal, color_err)
        if all_records is None:
            sys.exit(1)
        if not all_records:
            _msg("No login/auth events found in the journal directory.",
                 "bold_yellow", color_out)
            sys.exit(0)
        all_records.sort(key=_sort_key(FMT_JOURNAL), reverse=True)
        _emit(all_records, FMT_JOURNAL, args,
              [os.path.abspath(args.journal)], color_out)
        return

    # =======================================================================
    # Mode: wtmp/btmp/utmp/wtmpdb (-f)
    # =======================================================================
    file_info = []
    had_errors = False

    for fpath in args.file:
        fmt_key = _detect_format(fpath, color_err)
        if fmt_key is None:
            had_errors = True
            continue
        file_info.append((fpath, fmt_key))

    if not file_info:
        sys.exit(1 if had_errors else 0)

    fmt_keys = {info[1] for info in file_info}
    if len(fmt_keys) > 1:
        detected = ", ".join(sorted(FORMAT_LABELS.get(k, k) for k in fmt_keys))
        _msg(f"Error: Cannot mix different file types in the same execution.\n"
             f"       Detected formats: {detected}\n"
             f"       Please run {PROG} separately for each file type.",
             "bold_red", color_err, file=sys.stderr)
        sys.exit(1)

    fmt_key = fmt_keys.pop()

    all_records = []

    for fpath, _ in file_info:
        try:
            if fmt_key == FMT_WTMPDB:
                recs = _parse_wtmpdb_file(fpath)
            else:
                recs = _parse_legacy_file(fpath)
        except (ValueError, OSError) as exc:
            _msg(f"Error: {exc}", "bold_red", color_err, file=sys.stderr)
            had_errors = True
            continue

        for r in recs:
            r["source"] = fpath
        all_records.extend(recs)

    if not all_records:
        _msg("No records found in the provided file(s).", "bold_yellow", color_out)
        sys.exit(0)

    if fmt_key == FMT_LEGACY_WTMP:
        all_records = _match_sessions(all_records)

    if not args.show_all:
        if fmt_key == FMT_LEGACY_WTMP:
            all_records = [r for r in all_records if r["type"] in LEGACY_WTMP_DEFAULT_TYPES]
        elif fmt_key == FMT_WTMPDB:
            all_records = [r for r in all_records if r["type"] in WTMPDB_DEFAULT_TYPES]

    if not all_records:
        msg = "No matching records found."
        if fmt_key in (FMT_LEGACY_WTMP, FMT_WTMPDB):
            msg += " Try --all to show all record types."
        _msg(msg, "bold_yellow", color_out)
        sys.exit(0)

    all_records.sort(key=_sort_key(fmt_key), reverse=True)
    _emit(all_records, fmt_key, args,
          [os.path.abspath(fpath) for fpath, _ in file_info],
          color_out)


if __name__ == "__main__":
    main()
