# ---------------------------------------------------------------------------
# Auth / journal event patterns
# ---------------------------------------------------------------------------

_RE_SYSLOG_LINE = re.compile(r"^(\S+)\s+(\S+)\s+(.*)")

_RE_SSH_ACCEPTED = re.compile(
    r"sshd(?:-session)?\[(\d+)\]:\s*Accepted\s+(\S+)\s+for\s+(\S+)\s+from\s+(\S+)\s+port\s+(\d+)"
)
_RE_SSH_FAILED = re.compile(
    r"sshd(?:-session)?\[(\d+)\]:\s*Failed\s+password\s+for\s+(?:invalid\s+user\s+)?(\S+)\s+from\s+(\S+)\s+port\s+(\d+)"
)
_RE_AUTH_FAILURE = re.compile(
    r"pam_unix\(([^)]+):auth\):\s*authentication\s+failure;(.*)"
)
_RE_SUDO_CMD = re.compile(
    r"sudo:\s+(\S+)\s+:\s+TTY=(\S+)\s*;\s*PWD=([^;]*?)\s*;\s*USER=(\S+)\s*;\s*COMMAND=(.*)"
)
_RE_SUDO_DENIED = re.compile(
    r"sudo:\s+(\S+)\s+:\s+user\s+NOT\s+in\s+sudoers\s*;\s*TTY=(\S+)\s*;\s*PWD=([^;]*?)\s*;\s*USER=(\S+)\s*;\s*COMMAND=(.*)"
)
_RE_SUDO_AUTH_FAIL = re.compile(
    r"sudo:\s+pam_unix\(sudo:auth\):\s*authentication\s+failure;(.*)"
)
_RE_SU_OPEN = re.compile(
    r"su\[?(\d*)\]?:\s*pam_unix\(su[-l]*:session\):\s*session\s+opened\s+for\s+user\s+(\S+).*?by\s+(\S+)"
)
_RE_SU_FAILED = re.compile(
    r"su\[?(\d*)\]?:\s*FAILED\s+su\s+for\s+(\S+)\s+by\s+(\S+)"
)

def _strip_uid_suffix(name):
    """Strip trailing (uid=N) from a username captured by PAM regexes."""
    idx = name.find("(uid=")
    return name[:idx] if idx > 0 else name

