# Auth.log parsing
# ---------------------------------------------------------------------------

def _make_auth_record(timestamp_str, sort_us, hostname, event, user,
                      target_user, remote_ip, port, tty, command, pid,
                      service, source):
    return {
        "timestamp_str": timestamp_str,
        "sort_us": sort_us,
        "hostname": hostname,
        "event": event,
        "user": user,
        "target_user": target_user,
        "remote_ip": remote_ip,
        "port": port,
        "tty": tty,
        "command": command,
        "pid": pid,
        "service": service,
        "source": source,
    }


def _extract_kv(text, key):
    """Extract value for key= from a space/semicolon-separated string."""
    m = re.search(rf"(?:^|[\s;]){key}=(\S*)", text)
    return m.group(1) if m else ""


def _parse_auth_message(message, timestamp_str, sort_us, hostname, source):
    """Try to match a syslog message against known auth event patterns.
    Returns a record dict or None.
    """
    m = _RE_SSH_ACCEPTED.search(message)
    if m:
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "SSH Login",
            m.group(3), "", m.group(4), m.group(5), "", "",
            m.group(1), "sshd", source,
        )

    m = _RE_SSH_FAILED.search(message)
    if m:
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "SSH Failed Login",
            m.group(2), "", m.group(3), m.group(4), "", "",
            m.group(1), "sshd", source,
        )

    m = _RE_SUDO_DENIED.search(message)
    if m:
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "Sudo Denied",
            m.group(1), m.group(4), "", "", m.group(2), m.group(5).strip(),
            "", "sudo", source,
        )

    m = _RE_SUDO_CMD.search(message)
    if m:
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "Sudo Command",
            m.group(1), m.group(4), "", "", m.group(2), m.group(5).strip(),
            "", "sudo", source,
        )

    m = _RE_SUDO_AUTH_FAIL.search(message)
    if m:
        kv = m.group(1)
        user = _extract_kv(kv, "user") or _extract_kv(kv, "logname")
        tty = _extract_kv(kv, "tty")
        rhost = _extract_kv(kv, "rhost")
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "Sudo Auth Failure",
            user, "", rhost, "", tty, "", "", "sudo", source,
        )

    m = _RE_AUTH_FAILURE.search(message)
    if m:
        pam_service = m.group(1)
        kv = m.group(2)
        user = _extract_kv(kv, "user") or _extract_kv(kv, "logname")
        tty = _extract_kv(kv, "tty")
        rhost = _extract_kv(kv, "rhost")
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "Auth Failure",
            user, "", rhost, "", tty, "", "", pam_service, source,
        )

    m = _RE_SU_OPEN.search(message)
    if m:
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "Su Login",
            _strip_uid_suffix(m.group(3)), _strip_uid_suffix(m.group(2)),
            "", "", "", "",
            m.group(1), "su", source,
        )

    m = _RE_SU_FAILED.search(message)
    if m:
        return _make_auth_record(
            timestamp_str, sort_us, hostname, "Su Failed",
            _strip_uid_suffix(m.group(3)), _strip_uid_suffix(m.group(2)),
            "", "", "", "",
            m.group(1), "su", source,
        )

    return None


def _parse_auth_file(filepath):
    """Parse a single auth.log file (plain or .gz). Returns list of records."""
    records = []
    with _open_log_file(filepath) as fh:
        for line in fh:
            line = line.rstrip("\n")
            m = _RE_SYSLOG_LINE.match(line)
            if not m:
                continue
            ts_raw, hostname, rest = m.group(1), m.group(2), m.group(3)
            try:
                timestamp_str = _iso_to_utc_str(ts_raw)
                sort_us = _iso_to_epoch_us(ts_raw)
            except (ValueError, OSError):
                continue
            rec = _parse_auth_message(rest, timestamp_str, sort_us,
                                      hostname, filepath)
            if rec is not None:
                records.append(rec)
    return records


def _parse_auth_files(filepaths, color_err):
    """Parse one or more auth.log files. Returns list of records."""
    all_records = []
    for fpath in filepaths:
        if not os.path.exists(fpath):
            _msg(f"Error: File not found: {fpath}", "bold_red", color_err,
                 file=sys.stderr)
            continue
        if not os.path.isfile(fpath):
            _msg(f"Error: Not a regular file: {fpath}", "bold_red", color_err,
                 file=sys.stderr)
            continue
        try:
            recs = _parse_auth_file(fpath)
            all_records.extend(recs)
        except OSError as exc:
            _msg(f"Error: Cannot read {fpath}: {exc}", "bold_red", color_err,
                 file=sys.stderr)
    return all_records


# ---------------------------------------------------------------------------
# Journal parsing (via journalctl subprocess)
# ---------------------------------------------------------------------------

def _parse_journal(dirpath, color_err):
    """Parse a systemd journal directory via journalctl. Returns records."""
    if not os.path.isdir(dirpath):
        _msg(f"Error: Journal path is not a directory: {dirpath}",
             "bold_red", color_err, file=sys.stderr)
        return None

    if not shutil.which("journalctl"):
        _msg("Error: journalctl is not installed or not in PATH.\n"
             "       journalctl is required to read binary journal files.",
             "bold_red", color_err, file=sys.stderr)
        return None

    # Filter by SYSLOG_IDENTIFIER to avoid dumping the entire journal.
    # The '+' acts as OR between filter groups in journalctl.
    # Covers sshd (Ubuntu), sshd-session (Debian 13+), sudo, su, login,
    # GDM/LightDM auth, and systemd-logind.
    cmd = [
        "journalctl",
        f"--directory={dirpath}",
        "--output=json",
        "--no-pager",
        "SYSLOG_IDENTIFIER=sshd",
        "+", "SYSLOG_IDENTIFIER=sshd-session",
        "+", "SYSLOG_IDENTIFIER=sudo",
        "+", "SYSLOG_IDENTIFIER=su",
        "+", "SYSLOG_IDENTIFIER=login",
        "+", "SYSLOG_IDENTIFIER=systemd-logind",
        "+", "SYSLOG_IDENTIFIER=gdm-password]",
        "+", "SYSLOG_IDENTIFIER=gdm-session-worker",
        "+", "SYSLOG_IDENTIFIER=lightdm",
        "+", "SYSLOG_IDENTIFIER=polkitd",
    ]

    try:
        proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except OSError as exc:
        _msg(f"Error: Failed to run journalctl: {exc}", "bold_red", color_err,
             file=sys.stderr)
        return None

    records = []
    for line in proc.stdout:
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue

        rt_us_str = entry.get("__REALTIME_TIMESTAMP")
        if not rt_us_str:
            continue
        try:
            rt_us = int(rt_us_str)
        except (ValueError, TypeError):
            continue

        timestamp_str = _format_timestamp_us(rt_us)
        hostname = entry.get("_HOSTNAME", "")
        message = entry.get("MESSAGE", "")
        if not isinstance(message, str):
            continue

        svc_name = entry.get("SYSLOG_IDENTIFIER", entry.get("_COMM", ""))
        pid = entry.get("_PID", "")

        if svc_name == "sudo":
            full_message = f"sudo: {message}"
        elif pid:
            full_message = f"{svc_name}[{pid}]: {message}"
        else:
            full_message = f"{svc_name}: {message}"

        rec = _parse_auth_message(full_message, timestamp_str, rt_us,
                                  hostname, dirpath)
        if rec is not None:
            records.append(rec)

    stderr_out = proc.stderr.read()
    proc.wait()

    if proc.returncode != 0 and not records:
        _msg(f"Error: journalctl exited with code {proc.returncode}.\n"
             f"       {stderr_out.strip()}",
             "bold_red", color_err, file=sys.stderr)
        return None

    return records


# ---------------------------------------------------------------------------
# File-type detection
# ---------------------------------------------------------------------------

def _detect_format(filepath, use_color):
    """Return a format key (FMT_*) or None on error."""
    if not os.path.exists(filepath):
        _msg(f"Error: File not found: {filepath}", "bold_red", use_color,
             file=sys.stderr)
        return None

    if not os.path.isfile(filepath):
        _msg(f"Error: Not a regular file: {filepath}", "bold_red", use_color,
             file=sys.stderr)
        return None

    is_gz = filepath.endswith(".gz")

    if is_gz:
        try:
            with gzip.open(filepath, "rb") as f:
                raw = f.read()
        except (OSError, gzip.BadGzipFile) as exc:
            _msg(f"Error: Cannot decompress {filepath}: {exc}",
                 "bold_red", use_color, file=sys.stderr)
            return None
        file_size = len(raw)
        header = raw[:max(16, UTMP_STRUCT_SIZE)]
    else:
        try:
            file_size = os.path.getsize(filepath)
        except OSError as exc:
            _msg(f"Error: Cannot stat {filepath}: {exc}", "bold_red", use_color,
                 file=sys.stderr)
            return None

        try:
            with open(filepath, "rb") as f:
                header = f.read(max(16, UTMP_STRUCT_SIZE))
        except OSError as exc:
            _msg(f"Error: Cannot read {filepath}: {exc}", "bold_red", use_color,
                 file=sys.stderr)
            return None

    if file_size == 0:
        basename = os.path.basename(filepath).lower()
        if "btmp" in basename:
            return FMT_LEGACY_BTMP
        if "wtmp" in basename or "utmp" in basename:
            return FMT_LEGACY_WTMP
        _msg(f"Warning: {filepath} is empty and its type cannot be determined "
             f"from the filename.",
             "bold_yellow", use_color, file=sys.stderr)
        return None

    if not is_gz and len(header) >= 16 and header[:16] == SQLITE_MAGIC:
        return _detect_wtmpdb(filepath, use_color)

    if file_size < UTMP_STRUCT_SIZE:
        _msg(f"Error: {filepath} is not a recognized wtmp, btmp, or utmp file.\n"
             f"       File size ({file_size} bytes) is smaller than a single\n"
             f"       utmp record ({UTMP_STRUCT_SIZE} bytes).",
             "bold_red", use_color, file=sys.stderr)
        return None

    if len(header) >= 2:
        first_type = struct.unpack("<h", header[:2])[0]
        if first_type < 0 or first_type > 9:
            _msg(f"Error: {filepath} does not appear to be a wtmp, btmp, or utmp "
                 f"file.",
                 "bold_red", use_color, file=sys.stderr)
            return None

    if file_size % UTMP_STRUCT_SIZE != 0:
        remainder = file_size % UTMP_STRUCT_SIZE
        complete = file_size // UTMP_STRUCT_SIZE
        _msg(f"Warning: {filepath} has {remainder} trailing bytes after "
             f"{complete} complete record(s). The file may be truncated.\n"
             f"         Processing {complete} complete record(s).",
             "bold_yellow", use_color, file=sys.stderr)

    basename = os.path.basename(filepath).lower()
    if "btmp" in basename:
        return FMT_LEGACY_BTMP
    if "wtmp" in basename or "utmp" in basename:
        return FMT_LEGACY_WTMP

    records = _parse_legacy_file(filepath)
    type_set = {r["type"] for r in records}

    if 2 in type_set or 8 in type_set:
        return FMT_LEGACY_WTMP
    if type_set.issubset({0, 5, 6, 7}):
        return FMT_LEGACY_BTMP

    return FMT_LEGACY_WTMP


def _detect_wtmpdb(filepath, use_color):
    """Validate a SQLite file as wtmpdb. Return FMT_WTMPDB or None."""
    try:
        conn = sqlite3.connect(f"file:{filepath}?mode=ro", uri=True)
        cursor = conn.cursor()
        cursor.execute("SELECT name FROM sqlite_master WHERE type='table'")
        tables = {row[0] for row in cursor.fetchall()}
        conn.close()
    except sqlite3.Error as exc:
        _msg(f"Error: Cannot open SQLite database {filepath}: {exc}",
             "bold_red", use_color, file=sys.stderr)
        return None

    if "wtmp" in tables:
        return FMT_WTMPDB

    _msg(f"Error: {filepath} is a SQLite database but does not contain a\n"
         f"       'wtmp' table. It does not appear to be a wtmpdb file.",
         "bold_red", use_color, file=sys.stderr)
    return None


# ---------------------------------------------------------------------------
# Session matching (legacy wtmp only)
# ---------------------------------------------------------------------------

def _match_sessions(records):
    """Walk records newest-first, pairing USER_PROCESS with logout events."""
    sorted_recs = sorted(records, key=lambda r: (r["tv_sec"], r["tv_usec"]))

    next_event = {}

    for rec in reversed(sorted_recs):
        rt = rec["type"]

        if rt == 8:  # DEAD_PROCESS
            next_event[rec["line"]] = (rec["tv_sec"], rec["tv_usec"], "")

        elif rt == 2:  # BOOT_TIME
            next_event.clear()
            next_event["__BOOT__"] = (rec["tv_sec"], rec["tv_usec"], "down")

        elif rt == 7:  # USER_PROCESS
            line = rec["line"]
            matched = False

            if line in next_event:
                sec, usec, label = next_event[line]
                matched = True
            elif "__BOOT__" in next_event:
                sec, usec, label = next_event["__BOOT__"]
                matched = True

            if matched:
                rec["logout_str"] = _format_timestamp(sec, usec)
                if label:
                    rec["logout_str"] += f" ({label})"
                rec["duration_str"] = _format_duration(sec - rec["tv_sec"])
            else:
                rec["logout_str"] = "still logged in"
                rec["duration_str"] = ""

            next_event[line] = (rec["tv_sec"], rec["tv_usec"], "")

    return sorted_recs


# ---------------------------------------------------------------------------
# Hashing
# ---------------------------------------------------------------------------

def _sha256(filepath):
    """Return the SHA-256 hex digest of a file."""
    h = hashlib.sha256()
    with open(filepath, "rb") as f:
        for chunk in iter(lambda: f.read(1 << 20), b""):
            h.update(chunk)
    return h.hexdigest()


def _hash_sources(source_paths):
    """Compute SHA-256 for each source path. Returns {path: digest}."""
    hashes = {}
    for path in source_paths:
        if os.path.isdir(path):
            h = hashlib.sha256()
            journal_files = sorted(
                os.path.join(dirpath, fname)
                for dirpath, _, filenames in os.walk(path)
                for fname in filenames
                if fname.endswith(".journal")
            )
            for jf in journal_files:
                with open(jf, "rb") as f:
                    for chunk in iter(lambda: f.read(1 << 20), b""):
                        h.update(chunk)
            hashes[path] = h.hexdigest()
        elif os.path.isfile(path):
            hashes[path] = _sha256(path)
        else:
            hashes[path] = ""
    return hashes


# ---------------------------------------------------------------------------
# SQLite output (-s)
# ---------------------------------------------------------------------------

_PYLAST_LOG_DDL = """
CREATE TABLE IF NOT EXISTS pylast_log (
    id                INTEGER PRIMARY KEY AUTOINCREMENT,
    timestamp         TEXT    NOT NULL,
    type              TEXT    NOT NULL,
    path              TEXT    NOT NULL,
    action            TEXT    NOT NULL,
    records           INTEGER NOT NULL,
    pre_parse_sha256  TEXT    NOT NULL DEFAULT '',
    post_parse_sha256 TEXT    NOT NULL DEFAULT ''
)
"""


def _ensure_db(db_path, use_color):
    """Open (or create) the SQLite database and return (conn, created_flag)."""
    full_path = os.path.abspath(db_path)
    created = not os.path.exists(full_path)

    if created:
        _msg(f"Database not found. Creating: {full_path}",
             "bold_yellow", use_color)
    else:
        _msg(f"Database found: {full_path}", "bold_cyan", use_color)

    conn = sqlite3.connect(full_path)
    conn.execute(_PYLAST_LOG_DDL)
    conn.commit()
    return conn, full_path


def _log_import(conn, fmt_key, source_paths, action, record_count,
                pre_hashes=None, post_hashes=None):
    """Write one row per source path to pylast_log with SHA-256 hashes."""
    ts = datetime.now(tz=timezone.utc).strftime("%Y-%m-%d %H:%M:%S")
    type_label = FORMAT_TYPE_LABELS.get(fmt_key, fmt_key)
    pre = pre_hashes or {}
    post = post_hashes or {}
    for path in source_paths:
        conn.execute(
            "INSERT INTO pylast_log "
            "(timestamp, type, path, action, records, "
            " pre_parse_sha256, post_parse_sha256) "
            "VALUES (?, ?, ?, ?, ?, ?, ?)",
            (ts, type_label, path, action, record_count,
             pre.get(path, ""), post.get(path, "")),
        )
    conn.commit()


def _prompt_table_action(table_name, use_color):
    """Prompt the user to overwrite, append, or abort when the table exists."""
    if not sys.stdin.isatty():
        _msg(f"Table '{table_name}' already exists and stdin is not a TTY. "
             "Aborting.", "bold_yellow", use_color)
        return "aborted"

    _msg(f"Table '{table_name}' already exists.", "bold_yellow", use_color)
    print("  [o] Overwrite (drop and recreate)")
    print("  [a] Append rows to existing table")
    print("  [x] Abort")
    while True:
        try:
            choice = input("\n  Choice [o/a/x]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return "aborted"
        if choice in ("o", "overwrite"):
            return "refresh"
        if choice in ("a", "append"):
            return "append"
        if choice in ("x", "abort"):
            return "aborted"
        print("  Please enter o, a, or x.")


def _write_to_sqlite(db_path, records, fmt_key, source_paths, use_color):
    """Write records to a SQLite database. Returns True on success."""
    columns = FORMAT_COLUMNS[fmt_key]
    table_name = FORMAT_TABLE_NAMES[fmt_key]

    pre_hashes = _hash_sources(source_paths)

    conn, full_path = _ensure_db(db_path, use_color)

    cursor = conn.cursor()
    cursor.execute(
        "SELECT name FROM sqlite_master WHERE type='table' AND name=?",
        (table_name,),
    )
    table_exists = cursor.fetchone() is not None

    if table_exists:
        action = _prompt_table_action(table_name, use_color)
        if action == "aborted":
            _log_import(conn, fmt_key, source_paths, "aborted", 0,
                        pre_hashes=pre_hashes, post_hashes=pre_hashes)
            conn.close()
            _msg("Import aborted. No records were written.",
                 "bold_yellow", use_color)
            return False
        if action == "refresh":
            conn.execute(f"DROP TABLE [{table_name}]")
            conn.commit()
    else:
        action = "new"

    col_defs = []
    for header, key, _ in columns:
        sql_type = "INTEGER" if key in INTEGER_RECORD_KEYS else "TEXT"
        col_defs.append(f"  [{header}] {sql_type}")

    create_sql = (
        f"CREATE TABLE IF NOT EXISTS [{table_name}] (\n"
        + ",\n".join(col_defs)
        + "\n)"
    )
    conn.execute(create_sql)
    conn.commit()

    placeholders = ", ".join("?" for _ in columns)
    insert_sql = (
        f"INSERT INTO [{table_name}] "
        f"({', '.join(f'[{h}]' for h, _, _ in columns)}) "
        f"VALUES ({placeholders})"
    )

    row_count = 0
    for rec in records:
        values = []
        for _, key, _ in columns:
            val = rec.get(key, "")
            if key in INTEGER_RECORD_KEYS:
                try:
                    val = int(val) if val != "" else None
                except (ValueError, TypeError):
                    val = None
            else:
                val = str(val) if val is not None else ""
            values.append(val)
        conn.execute(insert_sql, values)
        row_count += 1

    conn.commit()

    post_hashes = _hash_sources(source_paths)
    _log_import(conn, fmt_key, source_paths, action, row_count,
                pre_hashes=pre_hashes, post_hashes=post_hashes)
    conn.close()

    _msg(f"Wrote {row_count} record(s) to table '{table_name}' in {full_path}",
         "bold_green", use_color)
    return True


# ---------------------------------------------------------------------------
# Display
# ---------------------------------------------------------------------------

def _row_color(fmt_key, rec):
    if fmt_key == FMT_LEGACY_BTMP:
        return "red"
    if fmt_key == FMT_LEGACY_WTMP:
        return LEGACY_WTMP_TYPE_COLORS.get(rec["type"])
    if fmt_key == FMT_WTMPDB:
        return WTMPDB_TYPE_COLORS.get(rec["type"])
    if fmt_key in (FMT_AUTH, FMT_JOURNAL):
        return AUTH_EVENT_COLORS.get(rec.get("event"))
    return None


def _print_records(records, fmt_key, use_tsv, use_color):
    if not records:
        return

    columns = FORMAT_COLUMNS[fmt_key]

    if use_tsv:
        print("\t".join(col[0] for col in columns))
        for rec in records:
            print("\t".join(str(rec.get(key, "")) for _, key, _ in columns))
        return

    widths = []
    for header, key, min_w in columns:
        w = max(len(header), min_w)
        for rec in records:
            w = max(w, len(str(rec.get(key, ""))))
        widths.append(w)

    hdr_parts = [h.ljust(w) for (h, _, _), w in zip(columns, widths, strict=True)]
    print(_color("  ".join(hdr_parts), "bold", use_color))
    print(_color("  ".join("\u2500" * w for w in widths), "gray", use_color))

    for rec in records:
        parts = [str(rec.get(key, "")).ljust(w) for (_, key, _), w in zip(columns, widths, strict=True)]
        line = "  ".join(parts)
        print(_color(line, _row_color(fmt_key, rec), use_color))


