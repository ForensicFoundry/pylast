def _color(text, style, use_color):
    if not use_color or not style:
        return str(text)
    code = ANSI.get(style)
    if not code:
        return str(text)
    return f"{code}{text}{ANSI['reset']}"


def _msg(text, style, use_color, *, file=None):
    """Print a styled message preceded by a blank line."""
    dest = file or sys.stdout
    print(f"\n{_color(text, style, use_color)}", file=dest)


